# Produção (Vercel) — requisições via proxy (vercel.json) apenas para o SIGEF
# O CAR usa acesso direto pois tem suporte a CORS e a Vercel dá erro 502 no proxy
VITE_CAR_ENDPOINT=https://geoserver.car.gov.br/geoserver/sicar/ows
# VITE_SIGEF_ENDPOINT=https://acervofundiario.incra.gov.br/i3geo/ogc.php
# Base URL definida pelo workflow do Actions (ex: /CARSIGEF/)
# Sobrescrito em runtime pelo vite.config.js via GITHUB_REPOSITORY
VITE_BASE_URL=/
